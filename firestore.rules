rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: batches
    // Fields:
    //   - name: string (required) - Name of the batch
    //   - date: timestamp (required) - Creation date
    //   - status: string (required) - Status (Aberto, Enviado, Finalizado)
    //   - ownerId: string (required) - UID of the creator
    //
    // Collection: orders
    // Fields:
    //   - shirtName: string (required) - Shirt description
    //   - size: string (required) - Size
    //   - personalization: string (optional) - Customization details
    //   - clientName: string (required) - Client name
    //   - photoUrl: string (optional) - Image URL
    //   - date: timestamp (required) - Order date
    //   - status: string (required) - Status (Pendente, Enviado ao fornecedor, Recebido)
    //   - batchId: string (required) - Reference to batch
    //   - ownerId: string (required) - UID of the creator
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isAuthenticated() && request.auth.uid == data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "enzofirmo14@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidBatch(data) {
      return data.keys().hasAll(['name', 'date', 'status', 'ownerId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.date is timestamp &&
             data.status in ['Aberto', 'Enviado', 'Finalizado'] &&
             data.ownerId == request.auth.uid &&
             (!('taxAmount' in data) || (data.taxAmount is number && data.taxAmount >= 0)) &&
             (!('dollarRate' in data) || (data.dollarRate is number && data.dollarRate >= 0));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['shirtName', 'model', 'size', 'clientName', 'date', 'status', 'batchId', 'ownerId', 'priceUsd', 'priceBrl', 'isPaid']) &&
             data.shirtName is string && data.shirtName.size() > 0 && data.shirtName.size() < 200 &&
             data.model is string &&
             data.size is string && data.size.size() > 0 && data.size.size() < 20 &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() < 100 &&
             data.date is timestamp &&
             data.status in ['Pendente', 'Enviado ao fornecedor', 'Recebido'] &&
             data.batchId is string &&
             data.ownerId == request.auth.uid &&
             data.priceUsd is number && data.priceUsd >= 0 &&
             data.priceBrl is number && data.priceBrl >= 0 &&
             data.isPaid is bool &&
             (!('paidAmount' in data) || (data.paidAmount is number && data.paidAmount >= 0)) &&
             (!('isStock' in data) || (data.isStock is bool)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() < 1000)) &&
             (!('personalization' in data) || (data.personalization is string && data.personalization.size() < 500)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000));
    }

    match /batches/{batchId} {
      allow read: if isAuthenticated() && (isOwner(resource.data) || isAdmin());
      allow create: if isAuthenticated() && isValidBatch(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data) || isAdmin()) && isValidBatch(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data) || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data) || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data) || isAdmin()) && isValidOrder(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data) || isAdmin());
    }
  }
}
